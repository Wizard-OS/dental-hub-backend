  "info": {
    "_postman_id": "f5f3b36d-4db2-4e5d-91c4-dentalhubbackend",
    "name": "DentalHub Backend API",
    "description": "Coleccion importable para DentalHub Backend. Ejecutar primero `00 Setup / Seed` y luego `00 Setup / Login`. La coleccion guarda automaticamente `token`, `clinicId` y IDs reutilizables para probar el flujo MVP multi-tenant.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{dentalhubToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('baseUrl')) {",
          "  pm.collectionVariables.set('baseUrl', 'http://localhost:3000/api');",
          "}",
          "",
          "const publicRequests = ['Seed', 'Login', 'Register User for Membership', 'Get FAQs', 'Get Contact Info'];",
          "const token = pm.collectionVariables.get('dentalhubToken') || pm.collectionVariables.get('token');",
          "if (token) {",
          "  pm.request.headers.upsert({ key: 'Authorization', value: `Bearer ${token}` });",
          "} else if (!publicRequests.includes(pm.info.requestName)) {",
          "  throw new Error('Falta token. Ejecuta primero 00 Setup / Login y verifica que la variable de coleccion token tenga valor.');",
          "}"
        ]
      }
    }
  ],

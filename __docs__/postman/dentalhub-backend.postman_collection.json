  "item": [
    {
      "name": "00 Setup",
      "item": [
        {
          "name": "Seed",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Seed ejecutado', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "if (json.clinicIds) {",
                  "  pm.collectionVariables.set('clinicMainId', json.clinicIds['clinic-main']);",
                  "  pm.collectionVariables.set('clinicEastId', json.clinicIds['clinic-east']);",
                  "  pm.collectionVariables.set('clinicId', json.clinicIds['clinic-main']);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/seed",
            "description": "Reinicia/carga datos seed. Guarda `clinicMainId`, `clinicEastId` y setea `clinicId` con la clinica principal."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login OK', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "const auth = json.data || json;",
                  "const token = auth.token || auth.accessToken || auth.jwt;",
                  "pm.test('Login devuelve token', function () { pm.expect(token, 'token').to.be.a('string').and.not.empty; });",
                  "if (token) {",
                  "  pm.collectionVariables.set('token', token);",
                  "  pm.collectionVariables.set('dentalhubToken', token);",
                  "}",
                  "if (auth.id) pm.collectionVariables.set('currentUserId', auth.id);",
                  "if (!pm.collectionVariables.get('clinicId') && Array.isArray(auth.memberships) && auth.memberships.length) {",
                  "  pm.collectionVariables.set('clinicId', auth.memberships[0].clinicId);",
                  "}",
                  "if (!pm.collectionVariables.get('clinicMembershipId') && Array.isArray(auth.memberships) && auth.memberships.length) {",
                  "  pm.collectionVariables.set('clinicMembershipId', auth.memberships[0].membershipId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test1@google.com\",\n  \"password\": \"Abc123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Autentica el usuario seed admin/owner y guarda `token`."
          }
        },
        {
          "name": "Check Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/check-status"
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/profile"
          }
        },
        {
          "name": "Set Active Clinic = Main",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('clinicId', pm.collectionVariables.get('clinicMainId'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('clinicId seteado a clinicMainId', function () {",
                  "  pm.expect(pm.collectionVariables.get('clinicId')).to.eql(pm.collectionVariables.get('clinicMainId'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/",
            "description": "Request utilitaria: setea `clinicId` con `clinicMainId` antes de ejecutarse."
          }
        }
      ]
